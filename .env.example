# Copy this file to .env.local and fill in real values from your
# Supabase project (Settings -> API). Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — used by user-actions.ts for auth.admin.inviteUserByEmail.
# NEVER prefix this with NEXT_PUBLIC_ or it will be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used to build the invite-email redirect link.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
