import Link from 'next/link';
import { notFound } from 'next/navigation';
import { getTranslations } from 'next-intl/server';
import { createClient, getCurrentAppUser } from '@/lib/supabase/server';
import { ArrowLeft } from 'lucide-react';
import InstallmentDetailClient from './installment-detail-client';

export default async function InstallmentDetailPage({
  params
}: {
  params: Promise<{ locale: string; contractId: string }>;
}) {
  const { locale, contractId } = await params;
  const t = await getTranslations('installments');
  const me = await getCurrentAppUser();
  const supabase = await createClient();

  const { data: contract } = await supabase
    .from('contracts')
    .select('*, customers(*), vehicles(brand, model, stock_code, engine_number, vin_number, license_plate, color, actual_cost)')
    .eq('id', contractId)
    .is('deleted_at', null)
    .single();

  if (!contract) notFound();
  if (!isPowerUser(me?.role) && contract.branch_id !== me?.branch_id) notFound();

  const { data: branches } = await supabase
    .from('branches')
    .select('id, branch_name')
    .eq('status', 'active')
    .is('deleted_at', null);

  return (
    <div>
      <Link
        href={`/${locale}/installments`}
        className="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 mb-4"
      >
        <ArrowLeft className="h-4 w-4" />
        {t('backToList')}
      </Link>
      <InstallmentDetailClient
        locale={locale}
        contract={contract as any}
        branches={branches ?? []}
      />
    </div>
  );
}
